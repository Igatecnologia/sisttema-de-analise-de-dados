# Dependências
node_modules/

# Build
dist/
dist-windows/
coverage/

# Ambiente
.env
.env.*
!.env.example
!.env.production

# Dados runtime (SQLite, secrets gerados, credenciais iniciais)
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
.session-jwt-secret
FIRST_LOGIN.txt

# Playwright + audit artefacts (gerados sob demanda)
apps/web/audit-results/
apps/web/test-results/
apps/web/playwright-report/
apps/web/tests/audit/.auth/
apps/web/tests/e2e/.auth/

# Sistema
*.log
*.rar
*.zip
.DS_Store
Thumbs.db

# Artefatos desktop/installer
desktop-app/
installer/
*.bat
*.exe
*.msi

# Config local do Claude Code:
# - settings.local.json: pessoal (env vars, API keys) — NÃO versionar
# - scheduled_tasks.lock: artefato runtime do ScheduleWakeup
# - settings.json e skills/ — versionar (compartilhado com time)
.claude/settings.local.json
.claude/scheduled_tasks.lock
*.html
# docs/ contém runbook de deploy + planos vivos + apresentações — versionar.
!docs/**/*.html

# Python runtime (iga-ai)
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
uv.lock
# tsc incremental build cache
**/tsconfig.tsbuildinfo
**/.next/

# Audit artifacts (regerados a cada audit)
audit-report.json
audit-report.md
audit-screenshots/
