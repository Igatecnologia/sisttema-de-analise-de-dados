# Porta do servidor (padrao: 3000)
PORT=3000

# Porta maxima quando PORT estiver ocupada (padrao: PORT + 20)
# PORT_MAX=3020

# URL do frontend para CORS (padrao: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Diretorio de dados persistentes (SQLite, backups e FIRST_LOGIN.txt)
# IGA_DATA_DIR=./data

# Admin inicial criado quando nao existe usuario no banco
# Em producao use uma senha forte e diferente por ambiente.
# ADMIN_DEFAULT_EMAIL=admin@iga.com
# ADMIN_DEFAULT_PASSWORD=SenhaForte@2026!

# Lista CSV de emails que tem acesso ao painel /super-admin (cross-tenant).
# Sem isso configurado, ninguem entra mesmo sendo admin do tenant.
# SUPER_ADMIN_EMAILS=admin@iga.com,outro@empresa.com

# Chave base64 de 32 bytes para criptografar segredos at rest.
# Obrigatoria em producao para evitar chave efemera.
# IGA_SECRETS_KEY=

# Diretorio opcional para servir o frontend buildado pelo Express
# SERVE_FRONTEND_DIR=./front-end-dist

# Preparacao SaaS (Sprint 0/1): usados pelo Docker Compose e pela migracao.
# Padrao: SQLite. Para validar os adaptadores de usuarios/datasources em PostgreSQL,
# rode as migrations/copia e habilite IGA_STORAGE_DRIVER=postgres.
# DATABASE_URL=postgresql://iga:iga_dev_password@localhost:5432/iga_gestao
# IGA_STORAGE_DRIVER=postgres
# POSTGRES_POOL_MAX=10
# POSTGRES_SSL=0
# REDIS_URL=redis://localhost:6379

# Billing real (Stripe). Em producao, nao use BILLING_GATE_DISABLED.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# BILLING_SUCCESS_URL=https://app.example.com/billing/sucesso
# BILLING_CANCEL_URL=https://app.example.com/billing/cancelado
# BILLING_PORTAL_RETURN_URL=https://app.example.com/billing

# JWT de sessao (HS256). Obrigatorio em producao; use 32+ bytes aleatorios.
# IGA_SESSION_JWT_SECRET=

# Credenciais SGBR BI (formato login:senha) — alternativa ao datasource config
# SGBR_CREDENTIALS=iga:123456

# URL base usada para criar a fonte SGBR default no seed inicial
# SGBR_API_URL=http://108.181.223.103:3007

# Endpoint oficial para alerta automatico de reconciliacao (obrigatorio para habilitar scheduler)
# RECONCILE_OFFICIAL_ENDPOINT=/sgbrbi/pedidos/listagem

# Limiar percentual de divergencia para disparar alerta (padrao: 1)
# RECONCILE_THRESHOLD_PCT=1

# Intervalo do monitoramento em milissegundos (padrao: 900000 = 15 minutos)
# RECONCILE_INTERVAL_MS=900000

# Opcional: trava reconciliacao para uma fonte especifica
# RECONCILE_SOURCE_ID=ds_xxxxxxxx

# Observabilidade (Sprint 7): logs JSON por request e por chamada proxy/data
# LOG_JSON_REQUESTS=1
# LOG_PROXY_DATA=1

# Timeout (ms) ao chamar API externa no proxy (SGBR lento em intervalos grandes). Padrao 120000.
# PROXY_UPSTREAM_TIMEOUT_MS=120000

# Deadline global (ms) para carregar dados paginados no proxy. Padrao 110000.
# PROXY_DATA_GLOBAL_DEADLINE_MS=110000

# Modo sequencial (API sem totalPages claro): max. de GETs extras apos a 1ª. Padrao 200.
# PROXY_DATA_MAX_AUTO_PAGES=200

# Quando a API informa totalPages, o proxy busca todas as paginas ate este indice (teto de seguranca). Padrao 5000.
# PROXY_DATA_MAX_PAGE_INDEX=5000

# Desliga busca automatica de paginas seguintes (so devolve o 1º JSON — mais rapido; pode truncar listas paginadas).
# PROXY_DATA_AUTO_PAGINATE=0

# Tamanho de pagina padrao (query `tamanho`) em fontes sgbr_bi quando o cliente nao envia — menos round-trips ate consumir tudo.
# SGBR_PROXY_DEFAULT_TAMANHO=500

# Cache em memoria do proxy
# PROXY_CACHE_TTL_MS=300000
# PROXY_CACHE_MAX_ENTRIES=50

# Permite testar APIs privadas/locais via datasource. Use apenas em dev.
# ALLOW_PRIVATE_HOSTS=localhost,127.0.0.1

# SMTP para relatorios agendados
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=0

# ─── Copiloto IA (gratuito) ─────────────────────────────────────────────────
# Preferencia: configure pela tela (engrenagem no copiloto). As env vars abaixo
# servem para deploy/CI e tem prioridade sobre a config salva no SQLite.
#
# Provider do copiloto: auto (default) | groq | local
# COPILOT_PROVIDER=auto
#
# Groq — free tier: 30 req/min, 14.400/dia, sem cartao. Obtenha em console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
