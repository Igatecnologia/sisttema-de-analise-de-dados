{
  "name": "iga-gestao-backend",
  "version": "1.2.0",
  "description": "Backend proxy para IGA Gestao — conecta APIs de clientes ao front-end",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate:pg": "tsx src/db/migratePostgres.ts",
    "db:copy:pg": "tsx src/db/copySqliteToPostgres.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=high",
    "sbom": "npx --yes @cyclonedx/cyclonedx-npm --output-format JSON --output-file dist/sbom.json",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.9",
    "@react-email/components": "^1.0.12",
    "@sentry/node": "^10.52.0",
    "@types/jsonwebtoken": "^9.0.10",
    "argon2": "^0.44.0",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.76.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
