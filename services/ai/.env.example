# IGA-AI service config
PORT=4000
LOG_LEVEL=INFO
ENV=development

# JWT shared secret entre Node backend e iga-ai (mesma chave nos dois lados)
# Gerar via: openssl rand -hex 48
IGA_AI_SHARED_SECRET=

# URL do Node backend (para chamar tools via REST)
NODE_BACKEND_URL=http://localhost:3000

# Provider IA primario: openai|anthropic|gemini (default: openai)
LLM_PROVIDER=openai

# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7

# Gemini (fallback)
GEMINI_API_KEY=

# RAG (AI-4)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
DATABASE_URL=postgresql://iga:iga@localhost:5432/iga_gestao

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=
