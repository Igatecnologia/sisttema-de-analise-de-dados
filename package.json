{
  "name": "iga-gestao-monorepo-tools",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0"
  },
  "lint-staged": {
    "front-end-gest-o/src/**/*.{ts,tsx}": [
      "npm --prefix front-end-gest-o run lint -- --fix"
    ],
    "back-end-gest-o/src/**/*.ts": [
      "npm --prefix back-end-gest-o run lint -- --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  }
}
