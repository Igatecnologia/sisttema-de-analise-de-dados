# Porta do servidor (padrao: 3000)
PORT=3000

# URL do frontend para CORS (padrao: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Credenciais SGBR BI (formato login:senha) — alternativa ao datasource config
# SGBR_CREDENTIALS=iga:123456

# Endpoint oficial para alerta automatico de reconciliacao (obrigatorio para habilitar scheduler)
# RECONCILE_OFFICIAL_ENDPOINT=/sgbrbi/pedidos/listagem

# Limiar percentual de divergencia para disparar alerta (padrao: 1)
# RECONCILE_THRESHOLD_PCT=1

# Intervalo do monitoramento em milissegundos (padrao: 900000 = 15 minutos)
# RECONCILE_INTERVAL_MS=900000

# Opcional: trava reconciliacao para uma fonte especifica
# RECONCILE_SOURCE_ID=ds_xxxxxxxx

# Observabilidade (Sprint 7): logs JSON por request e por chamada proxy/data
# LOG_JSON_REQUESTS=1
# LOG_PROXY_DATA=1

# Timeout (ms) ao chamar API externa no proxy (SGBR lento em intervalos grandes). Padrao 120000.
# PROXY_UPSTREAM_TIMEOUT_MS=120000

# Modo sequencial (API sem totalPages claro): max. de GETs extras apos a 1ª. Padrao 200.
# PROXY_DATA_MAX_AUTO_PAGES=200

# Quando a API informa totalPages, o proxy busca todas as paginas ate este indice (teto de seguranca). Padrao 5000.
# PROXY_DATA_MAX_PAGE_INDEX=5000

# Desliga busca automatica de paginas seguintes (so devolve o 1º JSON — mais rapido; pode truncar listas paginadas).
# PROXY_DATA_AUTO_PAGINATE=0

# Tamanho de pagina padrao (query `tamanho`) em fontes sgbr_bi quando o cliente nao envia — menos round-trips ate consumir tudo.
# SGBR_PROXY_DEFAULT_TAMANHO=500

# ─── Copiloto IA (gratuito) ─────────────────────────────────────────────────
# Preferencia: configure pela tela (engrenagem no copiloto). As env vars abaixo
# servem para deploy/CI e tem prioridade sobre a config salva no SQLite.
#
# Provider do copiloto: auto (default) | groq | local
# COPILOT_PROVIDER=auto
#
# Groq — free tier: 30 req/min, 14.400/dia, sem cartao. Obtenha em console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
